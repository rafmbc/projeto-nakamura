extends Node3D

signal wave_started
signal wave_hit_city
signal simulation_reset

@export var wave_speed: float = 60.0
@export var wave_height: float = 35.0
@export var wave_width: float = 700.0
@export var wave_depth: float = 80.0
@export var start_distance: float = 500.0

var _active: bool = false
var _wave_z: float = 0.0
var _elapsed: float = 0.0
var _hit_triggered: bool = false

# Mesh nodes
var _wave_body: MeshInstance3D
var _foam_top: MeshInstance3D
var _water_plane: MeshInstance3D

# Wave collision body — uses a thin ramp-shaped Area3D with multiple boxes
# so the hitbox matches the sloped face of the wave, not a floating cube
var _wave_collider: StaticBody3D
var _wave_col_shapes: Array[CollisionShape3D] = []

# Foam spray particles
var _spray_particles: GPUParticles3D

# Wave shader material (needs elapsed uniform update each frame)
var _wave_shader_mat: ShaderMaterial

# Base vertex data for animated breaking
var _base_verts: PackedVector3Array
var _base_normals: PackedVector3Array
var _wave_arr_mesh: ArrayMesh
var _W: int = 80
var _H: int = 40

func _ready() -> void:
	_build_water_plane()
	_build_wave()
	_build_spray_particles()
	_build_beach()
	_build_wave_collider()
	_reset()

# ─────────────────────────────────────────────────────────────────────────────
#  HELPERS
# ─────────────────────────────────────────────────────────────────────────────

func _make_noise_tex(freq: float, octaves: int, bump: float, as_normal: bool) -> NoiseTexture2D:
	var noise := FastNoiseLite.new()
	noise.noise_type = FastNoiseLite.TYPE_SIMPLEX_SMOOTH
	noise.frequency = freq
	noise.fractal_octaves = octaves
	var tex := NoiseTexture2D.new()
	tex.noise = noise
	tex.seamless = true
	tex.width = 512
	tex.height = 512
	tex.as_normal_map = as_normal
	tex.bump_strength = bump
	return tex

# ─────────────────────────────────────────────────────────────────────────────
#  1. WATER PLANE  — shader with noise normals, refraction, depth colour
# ─────────────────────────────────────────────────────────────────────────────

func _build_water_plane() -> void:
	_water_plane = MeshInstance3D.new()
	var m := PlaneMesh.new()
	m.size = Vector2(900, 1400)
	m.subdivide_width = 100
	m.subdivide_depth = 100
	_water_plane.mesh = m

	var noise_tex := _make_noise_tex(0.003, 4, 7.0, true)

	var shader := Shader.new()
	shader.code = """
shader_type spatial;
render_mode cull_back, diffuse_burley, specular_schlick_ggx;

uniform sampler2D noise_normal : hint_normal, repeat_enable;
uniform float uv_scale = 0.08;
uniform float tile_repeat = 3.0;
uniform float time_scale = 0.5;
uniform float intensity = 0.005;
uniform float normal_strength = 1.8;
uniform vec3 base_water = vec3(0.0, 0.35, 0.5);

varying vec2 world_xz;

const int MAX_ITER = 5;

vec3 water_turbulence(vec2 uv, float time) {
	vec2 p = mod(uv * TAU * tile_repeat, TAU) - 250.0;
	vec2 i = p;
	float c = 1.0;

	for (int n = 0; n < MAX_ITER; n++) {
		float t = time * (1.0 - (3.5 / float(n + 1)));
		i = p + vec2(cos(t - i.x) + sin(t + i.y), sin(t - i.y) + cos(t + i.x));
		c += 1.0 / length(vec2(p.x / (sin(i.x + t) / intensity), p.y / (cos(i.y + t) / intensity)));
	}

	c /= float(MAX_ITER);
	c = 1.17 - pow(c, 1.4);
	return clamp(vec3(pow(abs(c), 8.0)) + base_water, 0.0, 1.0);
}

void vertex() {
	world_xz = VERTEX.xz;
	float disp = texture(noise_normal, world_xz * uv_scale + vec2(TIME * 0.16, TIME * 0.12)).r;
	VERTEX.y += (disp - 0.5) * 0.8;
}

void fragment() {
	vec3 color = water_turbulence(UV, TIME * time_scale + 23.0);
	vec3 n1 = texture(noise_normal, world_xz * uv_scale + vec2(TIME * 0.20, TIME * 0.15)).rgb;
	NORMAL_MAP = normalize(n1 * 2.0 - 1.0);
	NORMAL_MAP_DEPTH = normal_strength;

	ALBEDO = color;
	ROUGHNESS = 0.18;
	METALLIC = 0.0;
	EMISSION = color * 0.05;
}
"""
	var mat := ShaderMaterial.new()
	mat.shader = shader
	mat.set_shader_parameter("noise_normal", noise_tex)
	mat.set_shader_parameter("uv_scale", 0.08)
	mat.set_shader_parameter("tile_repeat", 3.0)
	mat.set_shader_parameter("time_scale", 0.5)
	mat.set_shader_parameter("intensity", 0.005)
	mat.set_shader_parameter("normal_strength", 1.8)
	mat.set_shader_parameter("base_water", Vector3(0.0, 0.35, 0.5))

	_water_plane.material_override = mat
	_water_plane.position = Vector3(0, -0.5, -300)
	add_child(_water_plane)

# ─────────────────────────────────────────────────────────────────────────────
#  2. WAVE MESH  — animated breaking crest via vertex rebuild each frame
# ─────────────────────────────────────────────────────────────────────────────

func _build_wave() -> void:
	_wave_body = MeshInstance3D.new()
	_wave_arr_mesh = ArrayMesh.new()

	_base_verts   = PackedVector3Array()
	_base_normals = PackedVector3Array()
	var uvs       := PackedVector2Array()
	var indices   := PackedInt32Array()

	for row in range(_H + 1):
		var t_h: float = float(row) / float(_H)
		for col in range(_W + 1):
			var t_w: float = float(col) / float(_W)
			var x: float   = (t_w - 0.5) * wave_width
			var sw: float  = clamp(1.0 - pow(abs(t_w - 0.5) * 1.7, 2.2), 0.15, 1.0)

			var y: float
			var z: float
			var profile: float = sin(t_h * PI * 0.5)
			var front_bias: float = pow(t_h, 1.25)
			y = wave_height * (0.28 + 0.72 * profile) * (0.82 + 0.18 * front_bias)
			z = wave_depth * (0.19 + 0.81 * pow(t_h, 1.05))

			if t_h > 0.68:
				var crest_boost: float = pow((t_h - 0.68) / 0.32, 2.2)
				y += crest_boost * wave_height * 0.16
				z += crest_boost * wave_depth * 0.09

			y *= (0.58 + 0.42 * sw)
			z *= sw

			_base_verts.append(Vector3(x, y, z))

			var dz_val: float
			if t_h < 0.55:
				dz_val = wave_depth * sw * 3.0 * pow(t_h, 2.0) * 0.15
			else:
				dz_val = wave_depth * sw * 0.95 * 1.6 * pow((t_h - 0.55) / 0.45, 0.6) / 0.45
			var dy_val: float = wave_height * (1.05 if t_h < 0.55 else 0.52 / 0.45)
			_base_normals.append(Vector3(0.0, dz_val, -dy_val).normalized())
			uvs.append(Vector2(t_w, 1.0 - t_h))

	for row in range(_H):
		for col in range(_W):
			var tl: int = row * (_W + 1) + col
			indices.append_array([tl, tl + (_W + 1), tl + 1, tl + 1, tl + (_W + 1), tl + (_W + 2)])

	var arrays: Array = []
	arrays.resize(Mesh.ARRAY_MAX)
	arrays[Mesh.ARRAY_VERTEX] = _base_verts.duplicate()
	arrays[Mesh.ARRAY_NORMAL] = _base_normals.duplicate()
	arrays[Mesh.ARRAY_TEX_UV] = uvs
	arrays[Mesh.ARRAY_INDEX]  = indices
	_wave_arr_mesh.add_surface_from_arrays(Mesh.PRIMITIVE_TRIANGLES, arrays)

	# ── Wave face shader — matching the tiling turbulence water shader ───────
	var wave_noise := _make_noise_tex(0.006, 3, 5.0, true)
	var wave_shader := Shader.new()
	wave_shader.code = """
shader_type spatial;
render_mode blend_mix, depth_draw_always, cull_disabled, diffuse_burley, specular_schlick_ggx;

uniform sampler2D noise_normal : hint_normal, repeat_enable;
uniform float uv_scale = 0.014;
uniform float spd = 1.1;
uniform float time_scale = 0.5;
uniform float tile_repeat = 3.0;
uniform float intensity = 0.005;
uniform float normal_strength = 1.8;
uniform vec3 base_water = vec3(0.0, 0.35, 0.5);
uniform float break_t   : hint_range(0.0,1.0) = 0.0;

const int MAX_ITER = 5;

vec3 water_turbulence(vec2 uv, float time) {
	vec2 p = mod(uv * TAU * tile_repeat, TAU) - 250.0;
	vec2 i = p;
	float c = 1.0;

	for (int n = 0; n < MAX_ITER; n++) {
		float t = time * (1.0 - (3.5 / float(n + 1)));
		i = p + vec2(cos(t - i.x) + sin(t + i.y), sin(t - i.y) + cos(t + i.x));
		c += 1.0 / length(vec2(p.x / (sin(i.x + t) / intensity), p.y / (cos(i.y + t) / intensity)));
	}

	c /= float(MAX_ITER);
	c = 1.17 - pow(c, 1.4);
	return clamp(vec3(pow(abs(c), 8.0)) + base_water, 0.0, 1.0);
}

void fragment() {
	vec3 color = water_turbulence(UV, TIME * time_scale + 23.0);
	vec3 n1 = texture(noise_normal, UV * uv_scale + vec2(TIME * 0.20, TIME * 0.15)).rgb;
	NORMAL_MAP = normalize(n1 * 2.0 - 1.0);
	NORMAL_MAP_DEPTH = normal_strength;

	float turbulence = mix(0.0, 0.55, break_t);
	vec3 water_rgb = mix(color, vec3(0.82, 0.94, 0.98), turbulence * n1.r);
	float crest_sss = clamp((UV.y - 0.55) / 0.45, 0.0, 1.0) * (1.0 - break_t * 0.4);
	ALBEDO    = water_rgb;
	ALPHA     = mix(0.88, 0.55, break_t);
	ROUGHNESS = mix(0.05, 0.80, break_t);
	METALLIC  = mix(0.04, 0.0, break_t);
	EMISSION  = color * 0.05 * crest_sss;
}
"""
	_wave_shader_mat = ShaderMaterial.new()
	_wave_shader_mat.shader = wave_shader
	_wave_shader_mat.set_shader_parameter("noise_normal", wave_noise)
	_wave_shader_mat.set_shader_parameter("uv_scale",  0.014)
	_wave_shader_mat.set_shader_parameter("spd",       1.1)
	_wave_shader_mat.set_shader_parameter("time_scale", 0.5)
	_wave_shader_mat.set_shader_parameter("tile_repeat", 3.0)
	_wave_shader_mat.set_shader_parameter("intensity", 0.005)
	_wave_shader_mat.set_shader_parameter("normal_strength", 1.8)
	_wave_shader_mat.set_shader_parameter("base_water", Vector3(0.0, 0.35, 0.5))
	_wave_shader_mat.set_shader_parameter("break_t",   0.0)
	_wave_arr_mesh.surface_set_material(0, _wave_shader_mat)
	_wave_body.mesh = _wave_arr_mesh
	add_child(_wave_body)

	# ── FOAM CREST ────────────────────────────────────────────────────────────
	_foam_top = MeshInstance3D.new()
	var foam_arr := ArrayMesh.new()
	var fa: Array = []
	fa.resize(Mesh.ARRAY_MAX)
	var fv := PackedVector3Array()
	var fn := PackedVector3Array()
	var fu := PackedVector2Array()
	var fi := PackedInt32Array()
	var FW: int = 60
	var FH: int = 8

	for row in range(FH + 1):
		var t_h: float = float(row) / float(FH)
		for col in range(FW + 1):
			var t_w: float = float(col) / float(FW)
			var x: float   = (t_w - 0.5) * wave_width * 0.94
			var sf: float  = clamp(1.0 - pow(abs(t_w - 0.5) * 1.9, 2.0), 0.0, 1.0)
			var base_y: float = wave_height * (0.88 + t_h * 0.18) * (0.7 + 0.3 * sf)
			var fz: float     = pow(t_h, 1.7) * wave_depth * 1.42 * sf
			fv.append(Vector3(x, base_y, fz))
			fn.append(Vector3(0.0, 0.25, -0.97))
			fu.append(Vector2(t_w, t_h))

	for row in range(FH):
		for col in range(FW):
			var tl: int = row * (FW + 1) + col
			fi.append_array([tl, tl + (FW + 1), tl + 1, tl + 1, tl + (FW + 1), tl + (FW + 2)])

	fa[Mesh.ARRAY_VERTEX] = fv
	fa[Mesh.ARRAY_NORMAL] = fn
	fa[Mesh.ARRAY_TEX_UV] = fu
	fa[Mesh.ARRAY_INDEX]  = fi
	foam_arr.add_surface_from_arrays(Mesh.PRIMITIVE_TRIANGLES, fa)

	var foam_noise := _make_noise_tex(0.008, 3, 3.0, true)
	var foam_shader := Shader.new()
	foam_shader.code = """
shader_type spatial;
render_mode blend_mix, depth_draw_always, cull_disabled, diffuse_burley, specular_schlick_ggx;

uniform sampler2D noise_normal : hint_normal, repeat_enable;
// Off-white foam — not pure white, has a slight blue tint
uniform vec4  albedo    : source_color = vec4(0.88, 0.94, 0.98, 0.90);
uniform float roughness : hint_range(0.0,1.0) = 0.90;
uniform vec3  emit_col  : source_color = vec3(0.70, 0.82, 0.88);
uniform float emit_e    = 0.12;
uniform float spd       = 1.6;
uniform float break_t   : hint_range(0.0,1.0) = 0.0;

void fragment() {
	vec2 uv1 = UV + vec2(TIME * spd * 0.4, TIME * spd * 0.6);
	NORMAL_MAP = texture(noise_normal, uv1 * 0.3).rgb;
	NORMAL_MAP_DEPTH = 0.8;
	ALBEDO    = albedo.rgb;
	ALPHA     = mix(albedo.a, 0.25, break_t);
	ROUGHNESS = roughness;
	METALLIC  = 0.0;
	// Very subtle glow — just enough to catch specular light naturally
	EMISSION  = emit_col * emit_e * (1.0 - break_t * 0.5);
}
"""
	var fmat := ShaderMaterial.new()
	fmat.shader = foam_shader
	fmat.set_shader_parameter("noise_normal", foam_noise)
	fmat.set_shader_parameter("albedo",    Color(0.88, 0.94, 0.98, 0.90))
	fmat.set_shader_parameter("roughness", 0.90)
	fmat.set_shader_parameter("emit_col",  Color(0.70, 0.82, 0.88))
	fmat.set_shader_parameter("emit_e",    0.12)
	fmat.set_shader_parameter("spd",       1.6)
	fmat.set_shader_parameter("break_t",   0.0)
	foam_arr.surface_set_material(0, fmat)
	_foam_top.mesh = foam_arr
	add_child(_foam_top)

# ─────────────────────────────────────────────────────────────────────────────
#  3. SPRAY PARTICLES
# ─────────────────────────────────────────────────────────────────────────────

func _build_spray_particles() -> void:
	_spray_particles = GPUParticles3D.new()
	_spray_particles.amount = 400
	_spray_particles.lifetime = 1.8
	_spray_particles.emitting = false
	_spray_particles.one_shot = false
	_spray_particles.explosiveness = 0.0
	_spray_particles.visibility_aabb = AABB(
		Vector3(-wave_width * 0.6, 0, -20),
		Vector3(wave_width * 1.2, wave_height * 1.5, 60)
	)

	var pm := ParticleProcessMaterial.new()
	pm.emission_shape = ParticleProcessMaterial.EMISSION_SHAPE_BOX
	pm.emission_box_extents = Vector3(wave_width * 0.45, 2.0, 2.0)

	pm.direction         = Vector3(0.0, 1.0, -0.5)
	pm.spread            = 35.0
	pm.initial_velocity_min = 8.0
	pm.initial_velocity_max = 22.0
	pm.gravity           = Vector3(0, -18, 0)
	pm.scale_min         = 0.25
	pm.scale_max         = 0.9
	pm.color             = Color(0.90, 0.96, 1.0, 0.70)

	var fade_curve := Curve.new()
	fade_curve.add_point(Vector2(0.0, 1.0))
	fade_curve.add_point(Vector2(0.7, 0.8))
	fade_curve.add_point(Vector2(1.0, 0.0))
	var alpha_tex := CurveTexture.new()
	alpha_tex.curve = fade_curve
	pm.alpha_curve = alpha_tex

	_spray_particles.process_material = pm

	var smesh := SphereMesh.new()
	smesh.radius = 0.3
	smesh.height = 0.6
	var smat := StandardMaterial3D.new()
	smat.albedo_color      = Color(0.88, 0.95, 1.0, 0.75)
	smat.transparency      = BaseMaterial3D.TRANSPARENCY_ALPHA
	smat.emission_enabled  = true
	smat.emission          = Color(0.6, 0.78, 0.88)
	smat.emission_energy_multiplier = 0.15
	smesh.surface_set_material(0, smat)
	_spray_particles.draw_pass_1 = smesh

	add_child(_spray_particles)

# ─────────────────────────────────────────────────────────────────────────────
#  3b. BEACH  — procedural sand mesh with wet/foam zones and collision heightmap
# ─────────────────────────────────────────────────────────────────────────────

func _build_beach() -> void:
	var beach_mesh_inst := MeshInstance3D.new()
	var beach_arr_mesh := ArrayMesh.new()
	
	# Beach dimensions: Z from -185 (ocean) to -20 (city), X across wave width
	var beach_width: float = wave_width + 50.0
	var beach_length: float = 165.0
	var beach_subdiv_w: int = 80
	var beach_subdiv_d: int = 40
	
	# Procedural terrain noise for dune variation
	var _dune_noise := _make_noise_tex(0.008, 3, 2.0, false)
	
	var verts := PackedVector3Array()
	var norms := PackedVector3Array()
	var uvs := PackedVector2Array()
	var indices := PackedInt32Array()
	var heights := PackedFloat32Array()  # For HeightMapShape3D collision
	
	# Build beach mesh grid
	for row in range(beach_subdiv_d + 1):
		var t_d: float = float(row) / float(beach_subdiv_d)  # 0 (ocean) to 1 (city)
		var z: float = lerp(-185.0, -20.0, t_d)
		
		for col in range(beach_subdiv_w + 1):
			var t_w: float = float(col) / float(beach_subdiv_w)
			var x: float = (t_w - 0.5) * beach_width
			
			# Height profile: sine curve for beach shape
			var profile: float = sin(t_d * PI) * 2.5
			
			# Add dune bumps via noise (scale down so they don't interfere too much)
			var dune_scale: float = 0.8 * (0.6 + 0.4 * sin(t_d * PI))
			var dune_bump: float = (FastNoiseLite.new().get_noise_2d(x * 0.04, z * 0.04) + 1.0) * 0.5
			var y: float = profile + dune_bump * dune_scale - 0.3
			
			# Ocean edge dips below water so it blends seamlessly
			if t_d < 0.05:
				y -= (0.05 - t_d) * 1.2
			
			verts.append(Vector3(x, y, z))
			heights.append(y)
			
			# Normal is mostly up, with slight variation from noise
			norms.append(Vector3(0, 1, 0))
			
			# UV maps to beach zones: wet (y=0), foam (0.03), dry (>0.22)
			uvs.append(Vector2(t_w, t_d))
	
	# Build triangle indices
	for row in range(beach_subdiv_d):
		for col in range(beach_subdiv_w):
			var tl: int = row * (beach_subdiv_w + 1) + col
			indices.append_array([tl, tl + (beach_subdiv_w + 1), tl + 1, 
								  tl + 1, tl + (beach_subdiv_w + 1), tl + (beach_subdiv_w + 2)])
	
	# Assemble mesh
	var arrays: Array = []
	arrays.resize(Mesh.ARRAY_MAX)
	arrays[Mesh.ARRAY_VERTEX] = verts
	arrays[Mesh.ARRAY_NORMAL] = norms
	arrays[Mesh.ARRAY_TEX_UV] = uvs
	arrays[Mesh.ARRAY_INDEX] = indices
	beach_arr_mesh.add_surface_from_arrays(Mesh.PRIMITIVE_TRIANGLES, arrays)
	
	# Beach shader: uses imported PBR sand textures with depth-based blending
	var beach_shader := Shader.new()
	beach_shader.code = """
shader_type spatial;
render_mode blend_mix, diffuse_burley, specular_schlick_ggx;

uniform sampler2D sand_albedo : source_color, repeat_enable;
uniform sampler2D sand_normal : hint_normal, repeat_enable;
uniform sampler2D sand_roughness : repeat_enable;
uniform vec3 fallback_color : source_color = vec3(0.76, 0.70, 0.55);
uniform bool use_sand_texture = true;

uniform float wet_band : hint_range(0.0, 0.3) = 0.08;
uniform float foam_band : hint_range(0.0, 0.1) = 0.035;
uniform vec3 foam_col : source_color = vec3(0.88, 0.94, 0.98);
uniform float foam_roughness : hint_range(0.5, 1.0) = 0.88;
uniform float sand_uv_scale = 4.0;

void fragment() {
	float depth_in_beach = UV.y;
	vec2 sand_uv = UV * vec2(sand_uv_scale, 1.0);
	
	if (depth_in_beach < foam_band) {
		ALBEDO = foam_col;
		ROUGHNESS = foam_roughness;
	} else if (use_sand_texture) {
		vec3 sand_color = texture(sand_albedo, sand_uv).rgb;
		ALBEDO = sand_color;
		NORMAL_MAP = texture(sand_normal, sand_uv).rgb;
		ROUGHNESS = texture(sand_roughness, sand_uv).r;
		if (depth_in_beach < wet_band) {
			ALBEDO *= 0.85;
		}
	} else {
		ALBEDO = fallback_color;
		NORMAL_MAP = vec3(0.5, 0.5, 1.0);
		ROUGHNESS = 0.6;
	}
	METALLIC = 0.0;
}
"""
	
	var sand_albedo = ResourceLoader.load("res://textures/sand/Ground054_1K-JPG_Color.jpg")
	var sand_normal = ResourceLoader.load("res://textures/sand/Ground054_1K-JPG_NormalGL.jpg")
	var sand_rough = ResourceLoader.load("res://textures/sand/Ground054_1K-JPG_Roughness.jpg")
	
	var beach_mat := ShaderMaterial.new()
	beach_mat.shader = beach_shader
	beach_mat.set_shader_parameter("sand_albedo", sand_albedo if sand_albedo else Texture2D.new())
	beach_mat.set_shader_parameter("sand_normal", sand_normal if sand_normal else Texture2D.new())
	beach_mat.set_shader_parameter("sand_roughness", sand_rough if sand_rough else Texture2D.new())
	beach_mat.set_shader_parameter("use_sand_texture", sand_albedo != null and sand_normal != null and sand_rough != null)
	beach_mat.set_shader_parameter("wet_band", 0.08)
	beach_mat.set_shader_parameter("foam_band", 0.035)
	beach_mat.set_shader_parameter("foam_col", Color(0.88, 0.94, 0.98))
	beach_mat.set_shader_parameter("foam_roughness", 0.88)
	beach_mat.set_shader_parameter("sand_uv_scale", 4.0)
	beach_mat.set_shader_parameter("fallback_color", Color(0.76, 0.70, 0.55))
	beach_arr_mesh.surface_set_material(0, beach_mat)
	
	beach_mesh_inst.mesh = beach_arr_mesh
	add_child(beach_mesh_inst)
	
	# Beach collision — HeightMapShape3D for realistic walking
	var beach_collider := StaticBody3D.new()
	var beach_col_shape := CollisionShape3D.new()
	var heightmap := HeightMapShape3D.new()
	
	# HeightMapShape3D needs a 2D array of heights
	var hmap_data := PackedFloat32Array()
	for y in range(beach_subdiv_d + 1):
		for x in range(beach_subdiv_w + 1):
			var idx: int = y * (beach_subdiv_w + 1) + x
			hmap_data.append(heights[idx])
	
	heightmap.map_data = hmap_data
	heightmap.map_width = beach_subdiv_w + 1
	# Scale the heightmap to match world coords
	beach_col_shape.transform = Transform3D(
		Basis().scaled(Vector3(beach_width / float(beach_subdiv_w), 1.0, beach_length / float(beach_subdiv_d))),
		Vector3(-beach_width * 0.5, 0, -185.0)
	)
	beach_col_shape.shape = heightmap
	beach_collider.add_child(beach_col_shape)
	add_child(beach_collider)

# ─────────────────────────────────────────────────────────────────────────────
#  4. WAVE COLLIDER  — stepped ramp of boxes that matches the wave face slope
#     Each box covers one vertical section of the wave so the push zone
#     actually lines up with the visible water face.
# ─────────────────────────────────────────────────────────────────────────────

func _build_wave_collider() -> void:
	_wave_collider = StaticBody3D.new()

	# Use 4 stacked boxes to approximate the sloped wave face
	# Section 0: base/foot of wave  — wide, shallow, close to z=0
	# Section 3: crest              — narrower z-offset, highest y
	var sections: Array = [
		# [half_width_factor, height_centre_y, z_offset, box_half_height, box_half_z]
		[0.50, wave_height * 0.10, wave_depth * 0.08, wave_height * 0.14, wave_depth * 0.10],
		[0.50, wave_height * 0.32, wave_depth * 0.22, wave_height * 0.16, wave_depth * 0.10],
		[0.48, wave_height * 0.56, wave_depth * 0.38, wave_height * 0.16, wave_depth * 0.10],
		[0.44, wave_height * 0.82, wave_depth * 0.55, wave_height * 0.22, wave_depth * 0.10],
	]

	for sec in sections:
		var cs := CollisionShape3D.new()
		var box := BoxShape3D.new()
		box.size = Vector3(wave_width * sec[0] * 2.0, sec[3] * 2.0, sec[4] * 2.0)
		cs.shape = box
		cs.position = Vector3(0.0, sec[1], sec[2])
		_wave_collider.add_child(cs)
		_wave_col_shapes.append(cs)

	add_child(_wave_collider)

# ─────────────────────────────────────────────────────────────────────────────
#  RUNTIME
# ─────────────────────────────────────────────────────────────────────────────

func _reset() -> void:
	_active = false
	_wave_z = -start_distance
	_elapsed = 0.0
	_hit_triggered = false
	_apply_wave_transform()
	if _wave_body:       _wave_body.visible       = false
	if _foam_top:        _foam_top.visible         = false
	if _spray_particles: _spray_particles.emitting = false
	if _wave_collider:   _wave_collider.visible    = false
	if _wave_shader_mat:
		_wave_shader_mat.set_shader_parameter("break_t", 0.0)

func _apply_wave_transform() -> void:
	var pos := Vector3(0, 0, _wave_z)
	if _wave_body:     _wave_body.position     = pos
	if _foam_top:      _foam_top.position      = pos
	if _spray_particles:
		_spray_particles.position = Vector3(0, wave_height * 0.9, _wave_z + wave_depth * 0.8)
	if _wave_collider: _wave_collider.position = pos

func start() -> void:
	if _active: return
	_reset()
	_active = true
	_wave_body.visible       = true
	_foam_top.visible        = true
	_wave_collider.visible   = true
	emit_signal("wave_started")

func reset() -> void:
	_reset()
	emit_signal("simulation_reset")

func _process(delta: float) -> void:
	if not _active: return
	_elapsed += delta
	_wave_z += wave_speed * delta
	_apply_wave_transform()

	# ── Breaking animation ────────────────────────────────────────────────────
	var break_t: float = clamp((_wave_z + 60.0) / 120.0, 0.0, 1.0)
	_update_wave_verts(break_t)
	if _wave_shader_mat:
		_wave_shader_mat.set_shader_parameter("break_t", break_t)
	if _foam_top and _foam_top.mesh:
		var fm: ShaderMaterial = _foam_top.mesh.surface_get_material(0)
		if fm: fm.set_shader_parameter("break_t", break_t)

	# ── Spray particles ───────────────────────────────────────────────────────
	var spray_active: bool = _wave_z > -start_distance * 0.3
	if _spray_particles and _spray_particles.emitting != spray_active:
		_spray_particles.emitting = spray_active

	# ── Signals ───────────────────────────────────────────────────────────────
	if not _hit_triggered and _wave_z > -20.0:
		_hit_triggered = true
		emit_signal("wave_hit_city")

	if _wave_z > start_distance + 100.0:
		_active = false
		_wave_body.visible       = false
		_foam_top.visible        = false
		_wave_collider.visible   = false
		if _spray_particles: _spray_particles.emitting = false

# Rebuild only the vertex buffer each frame to animate the breaking curl
func _update_wave_verts(break_t: float) -> void:
	var new_verts   := PackedVector3Array()
	var new_normals := PackedVector3Array()
	new_verts.resize(_base_verts.size())
	new_normals.resize(_base_normals.size())

	var extra_curl: float = break_t * wave_depth * 1.05

	for row in range(_H + 1):
		var t_h: float = float(row) / float(_H)
		var curl_factor: float = clamp((t_h - 0.55) / 0.45, 0.0, 1.0)
		var crest: float = pow(curl_factor, 1.6)
		var dz: float = extra_curl * crest * (0.7 + 0.3 * t_h)
		var dy: float = -break_t * wave_height * 0.16 * pow(curl_factor, 2.0)
		var swell: float = sin(t_h * PI * 1.2 + _elapsed * 1.5) * 0.8 * break_t * (1.0 - crest)

		for col in range(_W + 1):
			var idx: int = row * (_W + 1) + col
			var sw: float = clamp(1.0 - pow(abs(float(col) / float(_W) - 0.5) * 1.7, 2.2), 0.15, 1.0)
			var side_flow: float = sin(float(col) / float(_W) * PI) * 2.4 * break_t * sw
			var base: Vector3 = _base_verts[idx]
			new_verts[idx]   = Vector3(base.x + side_flow, base.y + dy * sw + swell * sw, base.z + dz * sw)
			new_normals[idx] = _base_normals[idx]

	_wave_arr_mesh.surface_update_vertex_region(0, 0, new_verts.to_byte_array())

func is_active() -> bool:
	return _active

func get_wave_z() -> float:
	return _wave_z

func get_wave_progress() -> float:
	return clamp((_wave_z + start_distance) / (start_distance * 2.0 + 100.0), 0.0, 1.0)
